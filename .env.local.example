# ============ AI (OpenAI 协议,兼容 Codex 网关 / 官方 OpenAI / 其他兼容服务) ============

# 必填: API key
# 用 Codex 网关时填你的 sk-xxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选: 自定义网关 base_url
# 官方 OpenAI: 留空或 https://api.openai.com/v1
# Codex 网关:  https://modcon.top/v1
OPENAI_BASE_URL=https://modcon.top/v1

# 可选: 模型名
# 官方 OpenAI: gpt-4o-mini / gpt-4o
# Codex 网关:  gpt-5.4
OPENAI_MODEL=gpt-5.4

# ============ Farcaster ============
# 可选: Neynar API key (https://neynar.com/ 免费层够用)
# 不填会自动用 mock 数据,demo 完全能跑
NEYNAR_API_KEY=

# Sage 在 Farcaster 上的账号 fid (创建一个账号,把 fid 填这里)
SAGE_FID=0

# ============ Chain (测试网,可暂时留空) ============
# Base Sepolia RPC
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CHAIN_ID=84532

# 确定性地址盐(随便填一个字符串,后续上主网才需要改)
ADDRESS_SALT=sage-hackathon-2026

# ============ App ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
